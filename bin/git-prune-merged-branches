#!/bin/bash
#shellcheck disable=SC2076

set -eu
set -o pipefail

git fetch --all --prune

# Add --dry-run for testing
if [[ "${1:-}" == "--dry-run" ]]; then
  echo "Dry run mode enabled. No branches will be deleted."
  DRY_RUN=true
else
  DRY_RUN=false
fi

protected_branches=(
  c1-prod
  c1-zone-a
  c1-zone-b
  dev
  cf-dev
  cf-peli
  peli-cf-dev
  develop
  main
  master
  prod
  release
  test
)

gone_branches=$(git for-each-ref --format '%(refname) %(upstream:track)' refs/heads |\
  awk '$2 == "[gone]" {sub("refs/heads/", "", $1) ; print $1}')

echo >&2 "Found the following gone branches: ${gone_branches-}"

for branch in $gone_branches; do
  echo >&2 "Deleting branch $branch"
  # Check if branch is protected
  if [[ " ${protected_branches[*]} " =~ " ${branch} " ]]; then
    echo >&2 "Branch $branch is protected"
    continue
  fi
  if [[ "$DRY_RUN" == true ]]; then
    echo >&2 "Dry run: would delete branch $branch"
    continue
  fi
  git branch -D "$branch"
done

git gc --prune=now --aggressive
