#!/bin/bash

if [[ $# -lt 1 ]]; then
  echo >&2 "Usage: $0 <branch-name> [remote-name]"
  exit 1
fi

BRANCH=$1

# If branch starts with "origin/", remove the "origin/" prefix
BRANCH=${BRANCH#origin/}

if [[ $# -gt 1 ]]; then
  REMOTE=$2
else
  REMOTE=origin
fi

git branch -D "$BRANCH"
git push "$REMOTE" --delete "$BRANCH"
