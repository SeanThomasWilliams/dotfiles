#!/bin/bash
# Stop all running kind cluster containers
# Usage: kind-stop-clusters [-h]

set -euo pipefail

usage() {
  echo "Usage: ${0##*/} [-h]"
  echo "Stop all running kind cluster containers"
  echo ""
  echo "Options:"
  echo "  -h    Show this help message"
}

[[ "${1:-}" == "-h" ]] && { usage; exit 0; }

for cluster in $(kind get clusters 2>/dev/null); do
  containers=$(docker ps -q --filter "Name=${cluster}*")

  if [[ -n "$containers" ]]; then
    for container in $containers; do
      echo >&2 "Changing restart polcy on ${container}"
      docker update --restart=unless-stopped "${container}" &>/dev/null
    done

    echo >&2 "Stopping cluster: $cluster"
    docker stop $containers &>/dev/null
  else
    echo >&2 "Cluster already stopped: $cluster"
  fi
done
